{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/*"],
      "next/link": [".design-sync/shims/next-link.tsx"],
      "next/image": [".design-sync/shims/next-image.tsx"],
      "next/script": [".design-sync/shims/next-script.tsx"],
      "next/navigation": [".design-sync/shims/next-navigation.ts"],
      "path": [".design-sync/shims/node-path.ts"]
    }
  }
}
